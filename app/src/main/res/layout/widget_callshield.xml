<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FF0A0A0A"
    android:padding="12dp"
    android:gravity="center">

    <TextView
        android:id="@+id/widget_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CallShield"
        android:textColor="#FFA6E3A1"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_blocked_today"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0"
        android:textColor="#FF89B4FA"
        android:textSize="36sp"
        android:textStyle="bold"
        android:layout_marginTop="4dp" />

    <TextView
        android:id="@+id/widget_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="blocked today"
        android:textColor="#FFBAC2DE"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/widget_total"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0 total"
        android:textColor="#FF6C7086"
        android:textSize="11sp"
        android:layout_marginTop="4dp" />

</LinearLayout>
