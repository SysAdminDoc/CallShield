<?xml version="1.0" encoding="utf-8"?>
<!-- API 31+ backup/transfer rules (android:dataExtractionRules).
     Mirrors backup_rules.xml for cloud backup. Device-to-device
     transfer includes model weights too (regenerated on sync anyway). -->
<data-extraction-rules>
    <cloud-backup>
        <include domain="database" path="." />
        <include domain="file" path="datastore/" />
    </cloud-backup>
    <device-transfer>
        <include domain="database" path="." />
        <include domain="file" path="." />
    </device-transfer>
</data-extraction-rules>
